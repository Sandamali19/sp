@model SmartPostOffice.Models.ServiceRequest

<div class="container mt-4 mb-5">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-primary text-white py-3 text-center">
            <h3 class="mb-0"><i class="bi bi-mailbox2"></i> Smart Post - Service Registration</h3>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create">
                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="row">
                    <div class="col-md-12 mb-4">
                        <h5 class="text-primary border-bottom pb-2">Item & Pricing Details</h5>
                        <div class="row mt-3">
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-bold">Service Type</label>
                                <select asp-for="ServiceType" class="form-select border-primary">
                                    <option value="Ordinary Letter">Ordinary Letter</option>
                                    <option value="Registered Post">Registered Post</option>
                                    <option value="Speed Post">Speed Post</option>
                                    <option value="Parcel">Parcel</option>
                                </select>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-bold">Weight (grams)</label>
                                <input asp-for="Weight" type="number" step="0.01" class="form-control" placeholder="0.00" required />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-bold">Price (LKR)</label>
                                <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="0.00" required />
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 mb-4">
                        <div class="p-3 border rounded bg-light">
                            <h5 class="text-dark border-bottom pb-2">Sender Details</h5>
                            <div class="mb-3">
                                <label class="form-label">Full Name</label>
                                <input asp-for="SenderName" class="form-control" placeholder="Enter sender name" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Phone Number</label>
                                <input asp-for="SenderPhone" class="form-control" placeholder="07xxxxxxxx" required />
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 mb-4">
                        <div class="p-3 border rounded bg-light">
                            <h5 class="text-dark border-bottom pb-2">Receiver Details</h5>
                            <div class="mb-3">
                                <label class="form-label">Full Name</label>
                                <input asp-for="ReceiverName" class="form-control" placeholder="Enter receiver name" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Phone Number</label>
                                <input asp-for="ReceiverPhone" class="form-control" placeholder="07xxxxxxxx" required />
                            </div>
                        </div>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label class="form-label fw-bold">Full Destination Address</label>
                        <textarea asp-for="Destination" class="form-control border-primary" rows="3" placeholder="No, Street, City" required></textarea>
                    </div>
                </div>

                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-success btn-lg px-5 shadow-sm">
                        <i class="bi bi-cloud-upload"></i> Submit Request
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4 ms-2">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>