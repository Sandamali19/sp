@model IEnumerable<SmartPostOffice.Models.ServiceRequest>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-list-stars"></i> Registered Service Requests</h2>
        <a asp-action="Create" class="btn btn-primary">+ Register New Item</a>
    </div>

    <div class="card shadow">
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Ref Number</th>
                        <th>Type</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.ReferenceNumber</strong></td>
                            <td>@item.ServiceType</td>
                            <td>@item.CreatedDate?.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <span class="badge @(item.Status == "PENDING" ? "bg-warning text-dark" : "bg-success")">
                                    @item.Status
                                </span>
                            </td>
                            <td>
                                <a class="btn btn-sm btn-info text-white">View Details</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>